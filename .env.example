# Copia este archivo a .env.local y completa los valores.
# .env.local NO se sube a GitHub.

VITE_SUPABASE_URL=tu_url_de_supabase
VITE_SUPABASE_ANON_KEY=tu_anon_key

# Dominio interno para mapear usuario → email de Supabase (usuario@dominio)
VITE_AUTH_DOMAIN=pos.local

# Solo para el script local scripts/crear-usuario-admin.mjs (no uses prefijo VITE_)
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=tu_contraseña_segura
